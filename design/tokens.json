{
  "$schema": "https://design-tokens.org/schema.json",
  "_meta": {
    "name": "Wes Financial Auto",
    "theme": "dark",
    "description": "Design tokens. Mirror of styles/tokens.css. Edit both together."
  },
  "color": {
    "brand": {
      "red":  { "$value": "#E53845", "$type": "color" },
      "navy": { "$value": "#1D3558", "$type": "color" },
      "blue": { "$value": "#457B9D", "$type": "color" },
      "aqua": { "$value": "#A9DBDC", "$type": "color" },
      "mint": { "$value": "#F0FCEF", "$type": "color" },
      "deepDark": { "$value": "#0F1724", "$type": "color" }
    },
    "surface": {
      "0": { "$value": "#0F1724", "$type": "color" },
      "1": { "$value": "#16202E", "$type": "color" },
      "2": { "$value": "#1D2A3A", "$type": "color" },
      "3": { "$value": "#26384C", "$type": "color" },
      "inset": { "$value": "#0B121C", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "#F1F5F9", "$type": "color" },
      "secondary": { "$value": "#A9B7C6", "$type": "color" },
      "muted":     { "$value": "#647386", "$type": "color" },
      "disabled":  { "$value": "#3F4C5C", "$type": "color" },
      "inverse":   { "$value": "#0F1724", "$type": "color" }
    },
    "border": {
      "default":  { "$value": "#243140", "$type": "color" },
      "strong":   { "$value": "#34465A", "$type": "color" },
      "stronger": { "$value": "#46596E", "$type": "color" }
    },
    "role": {
      "accent":    { "$value": "#E53845", "$type": "color" },
      "accentHover": { "$value": "#D62B38", "$type": "color" },
      "info":      { "$value": "#457B9D", "$type": "color" },
      "success":   { "$value": "#3FB36B", "$type": "color" },
      "warning":   { "$value": "#E0A23C", "$type": "color" },
      "danger":    { "$value": "#E53845", "$type": "color" },
      "highlight": { "$value": "#A9DBDC", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "sans":    { "$value": "'DM Sans', -apple-system, 'Segoe UI', Helvetica, sans-serif", "$type": "fontFamily" },
      "display": { "$value": "'Oswald', 'DM Sans'", "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', ui-monospace, Menlo, monospace", "$type": "fontFamily" }
    },
    "size": {
      "_comment": "DESKTOP fixed px. Mobile (<=680px) overrides in sizeMobile.",
      "2xs": { "$value": "11px", "$type": "dimension" },
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "14px", "$type": "dimension" },
      "base":{ "$value": "16px", "$type": "dimension" },
      "md":  { "$value": "18px", "$type": "dimension" },
      "lg":  { "$value": "22px", "$type": "dimension" },
      "xl":  { "$value": "28px", "$type": "dimension" },
      "2xl": { "$value": "36px", "$type": "dimension" },
      "3xl": { "$value": "48px", "$type": "dimension" },
      "4xl": { "$value": "64px", "$type": "dimension" },
      "5xl": { "$value": "86px", "$type": "dimension" }
    },
    "sizeMobile": {
      "_comment": "Fixed px applied at <=680px. Mirror of the @media block in tokens.css.",
      "2xs": { "$value": "11px", "$type": "dimension" },
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "14px", "$type": "dimension" },
      "base":{ "$value": "16px", "$type": "dimension" },
      "md":  { "$value": "17px", "$type": "dimension" },
      "lg":  { "$value": "19px", "$type": "dimension" },
      "xl":  { "$value": "23px", "$type": "dimension" },
      "2xl": { "$value": "28px", "$type": "dimension" },
      "3xl": { "$value": "34px", "$type": "dimension" },
      "4xl": { "$value": "42px", "$type": "dimension" },
      "5xl": { "$value": "48px", "$type": "dimension" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    }
  },
  "space": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" },
    "32": { "$value": "128px","$type": "dimension" }
  },
  "radius": {
    "xs":   { "$value": "2px",   "$type": "dimension" },
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "base": { "$value": "8px",   "$type": "dimension" },
    "md":   { "$value": "12px",  "$type": "dimension" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "24px",  "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension" }
  },
  "shadow": {
    "sm":  { "$value": "0 1px 2px rgba(0,0,0,.4)",  "$type": "shadow" },
    "md":  { "$value": "0 4px 12px rgba(0,0,0,.45)", "$type": "shadow" },
    "lg":  { "$value": "0 12px 32px rgba(0,0,0,.55)","$type": "shadow" },
    "pop": { "$value": "0 8px 24px rgba(0,0,0,.5)",  "$type": "shadow" }
  },
  "overlay": {
    "_comment": "Token-based scrims for text-over-image, built from surface-0 via color-mix.",
    "scrim":       { "$value": "linear-gradient(to top, color-mix(in srgb, var(--surface-0) 92%, transparent), color-mix(in srgb, var(--surface-0) 45%, transparent) 45%, transparent 80%)", "$type": "gradient" },
    "scrimStrong": { "$value": "linear-gradient(to top, color-mix(in srgb, var(--surface-0) 96%, transparent), color-mix(in srgb, var(--surface-0) 60%, transparent))", "$type": "gradient" },
    "scrimFlat":   { "$value": "color-mix(in srgb, var(--surface-0) 55%, transparent)", "$type": "color" },
    "glass":       { "$value": "color-mix(in srgb, var(--surface-0) 82%, transparent)", "$type": "color" },
    "blurGlass":   { "$value": "12px", "$type": "dimension" }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "120ms", "$type": "duration" },
      "snap": { "$value": "180ms", "$type": "duration" },
      "base": { "$value": "250ms", "$type": "duration" },
      "slow": { "$value": "400ms", "$type": "duration" }
    },
    "easing": {
      "out":    { "$value": "cubic-bezier(.16,1,.3,1)", "$type": "cubicBezier" },
      "inOut":  { "$value": "cubic-bezier(.65,0,.35,1)", "$type": "cubicBezier" },
      "snap":   { "$value": "cubic-bezier(.2,.8,.2,1)",  "$type": "cubicBezier" }
    }
  },
  "layout": {
    "navHeight":  { "$value": "76px",   "$type": "dimension" },
    "container":  { "$value": "1280px", "$type": "dimension" },
    "containerNarrow": { "$value": "880px", "$type": "dimension" },
    "gutter":     { "$value": "64px", "$type": "dimension", "$description": "Desktop. Tablet 40px, mobile 20px." },
    "_sectionComment": "Asymmetric: text sits closer to the top edge, further from the bottom. Fixed px per breakpoint.",
    "sectionPt":   { "$value": "96px",  "$type": "dimension", "$description": "Section top padding. Tablet 72px, mobile 48px." },
    "sectionPb":   { "$value": "128px", "$type": "dimension", "$description": "Section bottom padding. Tablet 96px, mobile 64px." },
    "sectionSmPt": { "$value": "56px",  "$type": "dimension", "$description": "Tablet 44px, mobile 32px." },
    "sectionSmPb": { "$value": "72px",  "$type": "dimension", "$description": "Tablet 60px, mobile 44px." }
  },
  "rhythm": {
    "_comment": "Standard distances inside a section. Pick by relationship: text→text < text→object < block→block.",
    "text":    { "$value": "12px", "$type": "dimension", "$description": "text → text, same group (heading to its body, label to value)" },
    "textObj": { "$value": "24px", "$type": "dimension", "$description": "text → object / control (text block to card, image, form, button)" },
    "block":   { "$value": "48px", "$type": "dimension", "$description": "block → block within a section" }
  }
}
